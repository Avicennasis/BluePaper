* text=auto eol=lf

*.kt    text diff=kotlin
*.kts   text diff=kotlin
*.java  text diff=java
*.py text diff=python
*.sh text eol=lf
*.md text
*.yml text
*.yaml text
*.toml text
*.cfg text
*.ini text

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.aar binary
*.jar binary
*.apk binary

# Exclude from git archive (GitHub release tarballs)
.github/                 export-ignore
tests/                   export-ignore
bin/                     export-ignore
.gitattributes           export-ignore
.gitignore               export-ignore
.editorconfig            export-ignore
.pre-commit-config.yaml  export-ignore
CHANGELOG.md             export-ignore
CONTRIBUTING.md          export-ignore
CODE_OF_CONDUCT.md       export-ignore
SECURITY.md              export-ignore
